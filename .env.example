# DropHound configuration.
# Copy to `.env` (it is auto-loaded) and fill in only what you have.
# EVERYTHING is optional: with no keys set, the whole system runs in a safe,
# offline "dry-run" mode (sample monitor + fixture resale data + console alerts).

# --- Storage -------------------------------------------------------------
# Where the SQLite database lives. Defaults to <repo>/var/drophound.db
# DROPHOUND_DB_PATH=/absolute/path/to/drophound.db

# Public base URL, used to build links inside alerts/digests.
DROPHOUND_BASE_URL=http://localhost:8000

# Secret protecting the inbound POST /hook/restock webhook (how external page
# watchers / Zapier / scripts trigger a real alert). Unset = open, which is fine
# on localhost. Senders pass it as the `X-DropHound-Secret` header or `?secret=`.
# DROPHOUND_HOOK_SECRET=choose-a-long-random-string

# --- Layer 1: free funnel — alert channels ------------------------------
# Telegram channel/bot (BotFather token + the channel/chat id to post into).
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=@drophound        # or a numeric chat id

# Discord incoming webhook for the public #drops channel.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...

# Email delivery via Resend (https://resend.com — free tier works). Beehiiv works
# the same way. In test mode keep EMAIL_FROM as onboarding@resend.dev and set
# EMAIL_TO to the email you signed up to Resend with (free accounts can only send
# to your own address until you verify a domain).
# RESEND_API_KEY=re_...
# DROPHOUND_EMAIL_TO=you@youremail.com
# DROPHOUND_EMAIL_FROM=onboarding@resend.dev

# --- Resale intelligence: eBay sold listings ----------------------------
# eBay Finding API app id. Without it, resale stats come from bundled fixtures.
# EBAY_APP_ID=YourApp-1234-5678-9abc
# eBay Partner Network campaign id (affiliate links on outbound clicks).
# EBAY_CAMPAIGN_ID=5338xxxxxxx

# Other affiliate tags appended on outbound /go redirects.
# POPMART_AFFILIATE_REF=drophound
# STOCKX_AFFILIATE_REF=drophound

# --- Layer 2: billing (Stripe) ------------------------------------------
# Real subscription checkout. Set all three to collect payments:
#   - secret key from Stripe dashboard (sk_test_... or sk_live_...)
#   - price id of a recurring (monthly) Price you create in Stripe
#   - webhook signing secret (whsec_...) from the webhook endpoint you point at
#     https://<your-site>/stripe/webhook  (needed to grant access on payment)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
DROPHOUND_PREMIUM_PRICE=8

# --- AI layer: digest writer --------------------------------------------
# Anthropic API key turns the daily/weekly digest into punchy copy.
# Without it, a clean deterministic template is used.
# ANTHROPIC_API_KEY=sk-ant-...
DROPHOUND_DIGEST_MODEL=claude-sonnet-4-6

# --- Monitor tuning ------------------------------------------------------
# Seconds between cycles when running `cli run --loop`.
DROPHOUND_MONITOR_INTERVAL=300
# Polite delay (seconds) between HTTP fetches when using the real HttpMonitor.
DROPHOUND_HTTP_DELAY=2
